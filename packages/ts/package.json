{
  "name": "@responsibleapi/ts",
  "version": "1.0.8",
  "description": "TypeScript DSL for compiling OpenAPI 3.1 documents.",
  "keywords": [
    "api",
    "dsl",
    "openapi",
    "openapi-3.1",
    "typescript"
  ],
  "homepage": "https://github.com/responsibleapi/responsible/tree/master/packages/ts#readme",
  "bugs": {
    "url": "https://github.com/responsibleapi/responsible/issues"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/responsibleapi/responsible.git",
    "directory": "packages/ts"
  },
  "files": [
    "dist/**",
    "README.md",
    "UNLICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:slow": "vitest run src/",
    "typecheck": "tsc"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "@types/bun": "^1.3.13",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openapi-format": "^1.31.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "x-package-json-docs": "docs/package.jsonc"
}

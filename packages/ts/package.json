{
  "name": "@responsibleapi/ts",
  "version": "1.1.1",
  "description": "TypeScript DSL for compiling OpenAPI 3.1 documents.",
  "keywords": [
    "api",
    "dsl",
    "openapi",
    "openapi-3.1",
    "typescript"
  ],
  "homepage": "https://github.com/responsibleapi/responsible/tree/master/packages/ts#readme",
  "bugs": {
    "url": "https://github.com/responsibleapi/responsible/issues"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/responsibleapi/responsible.git",
    "directory": "packages/ts"
  },
  "files": [
    "dist/**",
    "README.md",
    "UNLICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "openapi3-ts": "^4.6.0"
  },
  "devDependencies": {
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "@types/bun": "^1.3.14",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openapi-format": "^1.33.5",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "x-package-json-docs": "docs/package.jsonc"
}
